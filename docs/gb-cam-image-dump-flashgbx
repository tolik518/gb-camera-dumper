## Rust Implementation Blueprint

This is not tied to any one PNG library. The important part is the parsing and 2bpp decode.

### Constants

```rust
const SAVE_SIZE: usize = 0x20000;
const PHOTO_DIRECTORY_SIZE: usize = 0x100000;
const PHOTO_DIRECTORY_ROLL_SIZE: usize = 0x20000;

const ORDER_OFFSET: usize = 0x11D7;
const ORDER_LEN: usize = 30;

const LAST_SEEN_OFFSET: usize = 0x0000;
const GAME_FACE_OFFSET: usize = 0x11FC;
const PHOTO_BASE_OFFSET: usize = 0x2000;
const PHOTO_STRIDE: usize = 0x1000;

const TILE_SIZE: usize = 16;
const TILE_COLUMNS: usize = 16;
const PHOTO_TILE_ROWS: usize = 14;
const LAST_SEEN_TILE_ROWS: usize = 16;

const WIDTH: usize = 128;
const PHOTO_HEIGHT: usize = 112;
const LAST_SEEN_CROP_HEIGHT: usize = 123;
```

### Palette model

```rust
#[derive(Clone, Copy, Debug)]
pub enum Palette {
    Grayscale,
    Dmg,
    Sgb,
    Cgb1,
    Cgb2,
    Cgb3,
}

pub fn palette_rgb(palette: Palette) -> [[u8; 3]; 4] {
    match palette {
        Palette::Grayscale => [[255,255,255], [176,176,176], [104,104,104], [0,0,0]],
        Palette::Dmg       => [[208,217,60],  [120,164,106], [84,88,84],   [36,70,36]],
        Palette::Sgb       => [[255,255,255], [181,179,189], [84,83,103],  [9,7,19]],
        Palette::Cgb1      => [[240,240,240], [218,196,106], [112,88,52],  [30,30,30]],
        Palette::Cgb2      => [[240,240,240], [220,160,160], [136,78,78],  [30,30,30]],
        Palette::Cgb3      => [[240,240,240], [134,200,100], [58,96,132],  [30,30,30]],
    }
}
```

### Normalize input

```rust
pub fn normalize_save<'a>(data: &'a [u8], roll: Option<usize>) -> Result<&'a [u8], String> {
    match data.len() {
        SAVE_SIZE => Ok(data),
        PHOTO_DIRECTORY_SIZE => {
            let roll = roll.ok_or("1 MiB Photo! Directory dump requires roll 0..7")?;
            if roll >= 8 {
                return Err(format!("invalid Photo! roll {roll}; expected 0..7"));
            }
            let start = roll * PHOTO_DIRECTORY_ROLL_SIZE;
            Ok(&data[start..start + PHOTO_DIRECTORY_ROLL_SIZE])
        }
        other => Err(format!("expected 0x20000 or 0x100000 bytes, got {other}")),
    }
}
```

### Album order parser

```rust
#[derive(Debug, Clone)]
pub struct AlbumOrder {
    pub display_to_physical: Vec<usize>,
    pub deleted_physical_slots: Vec<usize>,
    pub corrupt_values: Vec<(usize, u8)>,
}

pub fn parse_album_order(data: &[u8]) -> Result<AlbumOrder, String> {
    if data.len() != SAVE_SIZE {
        return Err("save must be 0x20000 bytes".into());
    }

    let raw = &data[ORDER_OFFSET..ORDER_OFFSET + ORDER_LEN];
    let mut display_to_physical: [Option<usize>; 30] = [None; 30];
    let mut deleted = Vec::new();
    let mut corrupt = Vec::new();
    let mut seen = [false; 30];

    for physical in 0..30 {
        let value = raw[physical];

        if value == 0xFF {
            deleted.push(physical);
            continue;
        }

        let display = value as usize;
        if display >= 30 {
            corrupt.push((physical, value));
            deleted.push(physical);
            continue;
        }

        if seen[display] {
            deleted.push(physical);
            continue;
        }

        seen[display] = true;
        display_to_physical[display] = Some(physical);
    }

    let mut order = display_to_physical
        .iter()
        .filter_map(|&slot| slot)
        .collect::<Vec<_>>();

    order.extend(deleted.iter().copied());

    Ok(AlbumOrder {
        display_to_physical: order,
        deleted_physical_slots: deleted,
        corrupt_values: corrupt,
    })
}
```

### 2bpp tile decode to palette indices

```rust
#[derive(Debug, Clone, Copy)]
pub enum ImageKind {
    Photo,
    GameFace,
    LastSeen,
}

pub fn decode_2bpp_tiles(buffer: &[u8], kind: ImageKind) -> Result<(Vec<u8>, usize, usize), String> {
    if buffer.len() < PHOTO_STRIDE {
        return Err(format!("image block too short: {} bytes", buffer.len()));
    }

    let tile_rows = match kind {
        ImageKind::Photo | ImageKind::GameFace => PHOTO_TILE_ROWS,
        ImageKind::LastSeen => LAST_SEEN_TILE_ROWS,
    };

    let decoded_height = tile_rows * 8;
    let output_height = match kind {
        ImageKind::LastSeen => LAST_SEEN_CROP_HEIGHT,
        _ => PHOTO_HEIGHT,
    };

    let mut indices = vec![0u8; WIDTH * output_height];

    for tile_y in 0..tile_rows {
        for tile_x in 0..TILE_COLUMNS {
            let tile_pos = TILE_SIZE * ((tile_y * TILE_COLUMNS) + tile_x);
            let tile = &buffer[tile_pos..tile_pos + TILE_SIZE];

            for row in 0..8 {
                let first_plane = tile[row * 2];
                let second_plane = tile[row * 2 + 1];

                for col in 0..8 {
                    let bit0 = (first_plane >> (7 - col)) & 1;
                    let bit1 = (second_plane >> (7 - col)) & 1;
                    let palette_index = (bit1 << 1) | bit0;

                    let x = tile_x * 8 + col;
                    let y = tile_y * 8 + row;

                    // Last Seen is decoded as 128x128, then cropped to 128x123.
                    if y < output_height && y < decoded_height {
                        indices[y * WIDTH + x] = palette_index;
                    }
                }
            }
        }
    }

    Ok((indices, WIDTH, output_height))
}
```

### Convert palette indices to RGBA

```rust
pub fn indices_to_rgba(indices: &[u8], palette: Palette) -> Vec<u8> {
    let pal = palette_rgb(palette);
    let mut rgba = Vec::with_capacity(indices.len() * 4);

    for &idx in indices {
        let [r, g, b] = pal[idx as usize];
        rgba.push(r);
        rgba.push(g);
        rgba.push(b);
        rgba.push(255);
    }

    rgba
}
```

### Extract all images

```rust
#[derive(Debug, Clone)]
pub struct ExtractedImage {
    pub filename: String,
    pub title: String,
    pub width: usize,
    pub height: usize,
    pub rgba: Vec<u8>,
    pub indices: Vec<u8>,
    pub offset: usize,
    pub display_index: Option<usize>,
    pub physical_slot: Option<usize>,
    pub deleted: bool,
}

pub fn extract_all(data: &[u8], palette: Palette) -> Result<Vec<ExtractedImage>, String> {
    let order = parse_album_order(data)?;
    let mut out = Vec::new();

    for display in 0..30 {
        let physical = *order.display_to_physical
            .get(display)
            .ok_or_else(|| format!("missing physical slot for display index {display}"))?;

        let offset = PHOTO_BASE_OFFSET + physical * PHOTO_STRIDE;
        let block = &data[offset..offset + PHOTO_STRIDE];
        let (indices, width, height) = decode_2bpp_tiles(block, ImageKind::Photo)?;
        let rgba = indices_to_rgba(&indices, palette);

        out.push(ExtractedImage {
            filename: format!("IMG_PC{:02}.png", display + 1),
            title: format!("Photo {:02}", display + 1),
            width,
            height,
            rgba,
            indices,
            offset,
            display_index: Some(display),
            physical_slot: Some(physical),
            deleted: order.deleted_physical_slots.contains(&physical),
        });
    }

    let game_face_block = &data[GAME_FACE_OFFSET..GAME_FACE_OFFSET + PHOTO_STRIDE];
    let (indices, width, height) = decode_2bpp_tiles(game_face_block, ImageKind::GameFace)?;
    out.push(ExtractedImage {
        filename: "IMG_PC31.png".into(),
        title: "Game Face".into(),
        width,
        height,
        rgba: indices_to_rgba(&indices, palette),
        indices,
        offset: GAME_FACE_OFFSET,
        display_index: None,
        physical_slot: None,
        deleted: false,
    });

    let last_seen_block = &data[LAST_SEEN_OFFSET..LAST_SEEN_OFFSET + PHOTO_STRIDE];
    let (indices, width, height) = decode_2bpp_tiles(last_seen_block, ImageKind::LastSeen)?;
    out.push(ExtractedImage {
        filename: "IMG_PC32.png".into(),
        title: "Last Seen Image".into(),
        width,
        height,
        rgba: indices_to_rgba(&indices, palette),
        indices,
        offset: LAST_SEEN_OFFSET,
        display_index: None,
        physical_slot: None,
        deleted: false,
    });

    Ok(out)
}
```

### Writing PNG in Rust

Using the `image` crate, the final step looks roughly like this:

```rust
use image::{ImageBuffer, Rgba};
use std::path::Path;

pub fn write_png(path: &Path, img: &ExtractedImage) -> Result<(), String> {
    let buffer: ImageBuffer<Rgba<u8>, Vec<u8>> = ImageBuffer::from_raw(
        img.width as u32,
        img.height as u32,
        img.rgba.clone(),
    ).ok_or("invalid RGBA buffer size")?;

    buffer.save(path).map_err(|e| e.to_string())
}
```

For an Android app, you can also skip PNG encoding for previews and pass `rgba`, `width`, and `height` to the UI layer. Encode only when the user taps Export.

