## Standalone Python Reference Extractor

This script mirrors the FlashGBX logic and adds support for `manifest.json`.

```python
#!/usr/bin/env python3
"""
Extract Game Boy Camera pictures from a 128 KiB .sav file.
Also supports slicing a 1 MiB Photo! Directory dump by roll.

Usage:
  python3 gbcam_sav_extract.py GAMEBOYCAMERA.sav out --palette grayscale
  python3 gbcam_sav_extract.py PHOTO_DIRECTORY.sav out --photo-slot 3
"""
from __future__ import annotations

import argparse
import hashlib
import json
from pathlib import Path
from PIL import Image, PngImagePlugin

PALETTES = {
    "grayscale": [255,255,255, 176,176,176, 104,104,104, 0,0,0],
    "dmg":       [208,217,60,  120,164,106, 84,88,84,   36,70,36],
    "sgb":       [255,255,255, 181,179,189, 84,83,103,  9,7,19],
    "cgb1":      [240,240,240, 218,196,106, 112,88,52,  30,30,30],
    "cgb2":      [240,240,240, 220,160,160, 136,78,78,  30,30,30],
    "cgb3":      [240,240,240, 134,200,100, 58,96,132,  30,30,30],
}

EMPTY_SHA1 = bytes.fromhex("ef58a812a81ab14549d8f4fb86e9ecb54a5fb723")


def normalize_save(data: bytes, photo_slot: int | None) -> bytes:
    if len(data) == 0x100000:
        if photo_slot is None:
            raise SystemExit("1 MiB Photo! Directory dump detected. Pass --photo-slot 0..7.")
        start = 0x20000 * photo_slot
        return data[start:start + 0x20000]

    if len(data) != 0x20000:
        raise SystemExit(f"Expected 128 KiB (0x20000), got {len(data)} bytes")

    return data


def parse_album_order(data: bytes):
    raw = data[0x11D7:0x11F5]
    order = [None] * 30
    deleted = []
    seen = []
    corrupt = []

    for physical_slot in range(30):
        value = raw[physical_slot]
        if value == 0xFF or value in seen:
            deleted.append(physical_slot)
        elif value >= 30:
            corrupt.append((physical_slot, value))
            deleted.append(physical_slot)
        else:
            order[value] = physical_slot
        seen.append(value)

    order = [slot for slot in order if slot is not None] + deleted
    return order, deleted, corrupt


def convert_picture(buf: bytes, palette: list[int], *, lastseen: bool = False) -> Image.Image:
    tile_width = 16
    tile_height = 16 if lastseen else 14
    height = 128 if lastseen else 112

    img = Image.new("P", (128, height))
    img.putpalette(palette)
    pixels = img.load()

    for tile_y in range(tile_height):
        for tile_x in range(tile_width):
            tile_pos = 16 * ((tile_y * tile_width) + tile_x)
            tile = buf[tile_pos:tile_pos + 16]
            if len(tile) < 16:
                continue

            for row in range(8):
                first_plane = tile[row * 2]
                second_plane = tile[row * 2 + 1]

                for col in range(8):
                    bit0 = (first_plane >> (7 - col)) & 1
                    bit1 = (second_plane >> (7 - col)) & 1
                    pixels[tile_x * 8 + col, tile_y * 8 + row] = (bit1 << 1) | bit0

    return img.crop((0, 0, 128, 123 if lastseen else 112))


def export_image(img: Image.Image, path: Path, title: str, scale: int):
    if scale != 1:
        img = img.resize((img.width * scale, img.height * scale), Image.Resampling.NEAREST)
    meta = PngImagePlugin.PngInfo()
    meta.add_text("Software", "gbcam_sav_extract.py / FlashGBX-compatible layout")
    meta.add_text("Title", title)
    img.save(path, pnginfo=meta)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("sav", type=Path)
    ap.add_argument("out", type=Path)
    ap.add_argument("--palette", choices=PALETTES.keys(), default="grayscale")
    ap.add_argument("--scale", type=int, default=1)
    ap.add_argument("--photo-slot", type=int, choices=range(8), metavar="0-7")
    args = ap.parse_args()

    data = normalize_save(args.sav.read_bytes(), args.photo_slot)
    args.out.mkdir(parents=True, exist_ok=True)

    palette = PALETTES[args.palette]
    order, deleted, corrupt = parse_album_order(data)
    manifest = []

    for display_index in range(30):
        physical = order[display_index]
        off = 0x2000 + physical * 0x1000
        img = convert_picture(data[off:off + 0x1000], palette)
        title = f"Photo {display_index + 1:02d}"
        fn = args.out / f"IMG_PC{display_index + 1:02d}.png"
        export_image(img, fn, title, args.scale)
        manifest.append({
            "file": fn.name,
            "title": title,
            "display_index": display_index,
            "physical_slot": physical,
            "offset": f"0x{off:05X}",
            "deleted": physical in deleted,
            "empty": hashlib.sha1(img.tobytes()).digest() == EMPTY_SHA1,
        })

    game_face = convert_picture(data[0x11FC:0x11FC + 0x1000], palette)
    export_image(game_face, args.out / "IMG_PC31.png", "Game Face", args.scale)
    manifest.append({"file": "IMG_PC31.png", "title": "Game Face", "offset": "0x011FC"})

    last_seen = convert_picture(data[0:0x1000], palette, lastseen=True)
    export_image(last_seen, args.out / "IMG_PC32.png", "Last Seen Image", args.scale)
    manifest.append({"file": "IMG_PC32.png", "title": "Last Seen Image", "offset": "0x00000"})

    if corrupt:
        manifest.append({"warning": "corrupt order-table values", "values": corrupt})

    (args.out / "manifest.json").write_text(json.dumps(manifest, indent=2), encoding="utf-8")
    print(f"Wrote {len(manifest)} manifest entries to {args.out}")


if __name__ == "__main__":
    main()
```

